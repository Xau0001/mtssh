# Maintainer: Xau0001 <https://github.com/Xau0001>
pkgname=mtssh
pkgver=1.0.0
pkgrel=1
pkgdesc="Multi-Tabbed SSH Client — Graphical SSH tool with SFTP, themes, AES-encrypted sessions"
arch=('x86_64' 'aarch64')
url="https://github.com/Xau0001/mtssh"
license=('MIT')
depends=('glibc' 'mesa' 'libx11' 'libxrandr' 'libxcursor' 'libxinerama' 'libxi')
makedepends=('go' 'gcc' 'git')
source=("$pkgname::git+https://github.com/Xau0001/mtssh.git#tag=v$pkgver")
sha256sums=('SKIP')

build() {
    cd "$srcdir/$pkgname"
    export CGO_ENABLED=1
    export GOFLAGS="-buildmode=pie -trimpath -ldflags=-linkmode=external"
    go build -v \
        -ldflags "-s -w -X main.Version=$pkgver" \
        -o mtssh .
}

package() {
    cd "$srcdir/$pkgname"
    install -Dm755 mtssh "$pkgdir/usr/bin/mtssh"
    install -Dm644 install/mtssh.desktop "$pkgdir/usr/share/applications/mtssh.desktop"
}

# ── Local install without AUR ─────────────────────────────────────────────────
# To install directly from the cloned repo (no GitHub release needed):
#
#   bash install/install-linux.sh
